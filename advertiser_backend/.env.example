# =============================================
# Required Environment Variables
# =============================================
# Copy this file to .env or set these as OS-level env vars

DATABASE_URL=jdbc:postgresql://your-host:5432/your-db?sslmode=require
DATABASE_USERNAME=your-username
DATABASE_PASSWORD=your-password

# =============================================
# For IntelliJ IDEA: Settings → Build, Execution, Deployment
#   → Build Tools → Maven → Runner → Environment variables
# For VS Code launch.json: add "env" block
JWT_SECRET=MySuperSecretKeyForHS256AlgorithmThatIsAtLeast32Chars!!

# For command line: $env:DATABASE_URL="..." (PowerShell)
#                  export DATABASE_URL="..."  (bash)
